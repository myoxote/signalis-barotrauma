<Talents>
  <Talent identifier="coolhead">
    <Icon texture="Content/UI/TalentsIcons1.png" sheetindex="6,1" sheetelementsize="128,128" />
    <Description tag="talentdescription.coolhead">
      <Replace tag="[amount1]" value="6" color="gui.green" />
      <Replace tag="[amount2]" value="20" color="gui.green" />
    </Description>
    <Description tag="talentdescription.unlockrecipe">
      <Replace tag="[itemname]" value="entityname.cigar" color="gui.orange" />
    </Description>
    <AbilityGroupInterval interval="1">
      <Abilities>
        <CharacterAbilityModifyAttackData addeddamagemultiplier="0.06" />
        <CharacterAbilityModifyStat stattype="RangedSpreadReduction" value="0.2" />
      </Abilities>
    </AbilityGroupInterval>
    <AddedRecipe itemidentifier="cigar" />
  </Talent>
  <Talent identifier="relaxed">
