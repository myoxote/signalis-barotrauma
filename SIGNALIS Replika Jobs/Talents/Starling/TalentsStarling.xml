        <CharacterAbilityGiveStat stattype="RepairSpeed" value="-0.2" />
      </Abilities>
    </AbilityGroupEffect>
  </Talent>
  <Talent identifier="hazingrituals">
    <Icon texture="Content/UI/TalentsIcons1.png" sheetindex="5,5" sheetelementsize="128,128" />
    <Description tag="talentdescription.hazingrituals">
      <Replace tag="[amount]" value="50" color="gui.green" />
      <Replace tag="[STAR]" value="STARs" color="gui.orange" />
    </Description>
    <!-- give XP to the character itself -->
    <AbilityGroupEffect abilityeffecttype="OnGainMissionExperience">
      <Conditions>
        <AbilityConditionLowestLevel />
        <AbilityConditionJobIdentifier jobidentifier="Starling" />
      </Conditions>
      <Abilities>
        <CharacterAbilityModifyValue multiplyvalue="1.5" />
      </Abilities>
    </AbilityGroupEffect>
    <!-- allies too -->
    <AbilityGroupEffect abilityeffecttype="OnAllyGainMissionExperience">
      <Conditions>
        <AbilityConditionLowestLevel />
        <AbilityConditionJobIdentifier jobidentifier="Starling" />
      </Conditions>
      <Abilities>
        <CharacterAbilityModifyValue multiplyvalue="1.5" />
      </Abilities>
    </AbilityGroupEffect>
  </Talent>
